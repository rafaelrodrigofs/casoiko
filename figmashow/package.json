{
  "name": "figmashow",
  "version": "1.0.1",
  "private": true,
  "description": "FigmaShow — editor de telas mobile + MCP local/remoto",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mcp": "npm run start -w @figmashow/mcp",
    "web": "npm run dev -w @figmashow/web",
    "dev": "npm run web",
    "build": "npm run build -w @figmashow/web",
    "start": "npm run start -w @figmashow/server",
    "test": "node --test packages/core/src/*.test.js",
    "test:e2e": "playwright test",
    "backup": "node scripts/backup-data.mjs",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "smoke:mcp": "node scripts/smoke-mcp-http.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
